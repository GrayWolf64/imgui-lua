{
    "diagnostics.disable": [
        "need-check-nil",
        "undefined-field",
        "inject-field",
        "lowercase-global",

        // FIXME: remove those below when it's fixed
        // https://github.com/LuaLS/lua-language-server/issues/1456
        "cast-local-type",
        "param-type-mismatch",
        "assign-type-mismatch",
        "return-type-mismatch"
    ],
    "checkThirdParty": false,
    "runtime.special": {
        "include": "dofile",
        "IncludeCS": "dofile"
    },
    "runtime.nonstandardSymbol": [
        "continue"
    ],
    "workspace.library": [
        "${addons}/garrysmod/module/library"
    ],
    "runtime.version": "LuaJIT"
}